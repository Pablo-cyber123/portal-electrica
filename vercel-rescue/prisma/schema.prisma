generator client {
  provider = "prisma-client-js"
}

model AppSetting {
  key   String @id
  value String
}

datasource db {
  provider = "postgresql"
}

// 1. Usuarios y Seguridad
model User {
  id             String           @id @default(uuid())
  email          String           @unique
  name           String
  password       String
  role           String           // "ADMIN", "TEACHER", "STUDENT"
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  notifications  StudentNotification[]
  createdAt      DateTime         @default(now())
}

// 2. Perfiles extendidos
model StudentProfile {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  code         String? @unique
  status       String @default("ACTIVE")
  createdAt    DateTime @default(now())
  
  // Relaciones
  projects     ResearchProjectStudent[]
  idea         DegreeProjectIdea?
  enrollments  Enrollment[]
}

model TeacherProfile {
  id             String @id @default(uuid())
  userId         String @unique
  user           User   @relation(fields: [userId], references: [id])
  employeeId     String? @unique
  department     String?
  createdAt      DateTime @default(now())
  
  // Relaciones
  ledProjects    ResearchProject[]
  subjects       Subject[]
}

// 3. Materias y Evaluaciones
model Subject {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  credits     Int
  semester    Int
  
  enrollments Enrollment[]
  announcements SubjectAnnouncement[]
  gradoProjects DegreeProject[]
}

model Enrollment {
  id          String   @id @default(uuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])
  teacherId   String?  // Denormalization
  status      String   @default("ENROLLED")

  // Habilitaciones
  habilitationEnabled     Boolean?
  habilitationEnabledAt   DateTime?
  habilitationProofUrl    String?
  habilitationScore       Float?

  grades      Grade[]
  enrolledAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([studentId, subjectId])
}

model Grade {
  id            String   @id @default(uuid())
  enrollmentId  String
  enrollment    Enrollment @relation(fields: [enrollmentId], references: [id])
  cutNumber     Int      // 1, 2, 3
  
  rawEvaluations Float[]
  rawTasks      Float[]
  
  evaluationScore Float
  tasksScore    Float
  selfEvaluationScore Float
  score         Float
  
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([enrollmentId, cutNumber])
}

model SubjectAnnouncement {
  id        String   @id @default(uuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

// 4. Proyectos de Grado y Entregas
model DegreeProjectSubmissionWindow {
  id                 String   @id @default(uuid())
  title              String
  submissionDeadline DateTime
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model DegreeProjectIdea {
  id               String   @id 
  studentId        String   @unique
  student          StudentProfile @relation(fields: [studentId], references: [id])
  title            String
  summary          String   @db.Text
  documentUrl      String
  fileName         String
  status           String   @default("PENDIENTE_REVISION")
  teacherFeedback  String?  @db.Text
  reviewedByUserId String?  
  reviewedAt       DateTime?
  submittedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StudentNotification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ideaId    String?
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DegreeProject {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  status      String   // PROPOSED, APPROVED, IN_PROGRESS, DEFENDED
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  createdAt   DateTime @default(now())
}

// 5. Sistema de Noticias
model News {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  imageUrl  String?
  linkUrl   String?
  videoUrl  String?
  authorId  String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}


// 6. Semillero de Investigación (AGE)
model ResearchProject {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  teacherId   String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  status      String   // "ACTIVE", "COMPLETED"
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  
  students    ResearchProjectStudent[]
  tasks       ProjectTask[]
  updates     ProjectUpdate[]
}

model ResearchProjectStudent {
  id          String @id @default(uuid())
  projectId   String
  studentId   String
  project     ResearchProject @relation(fields: [projectId], references: [id])
  student     StudentProfile  @relation(fields: [studentId], references: [id])
  role        String?
  joinedAt    DateTime @default(now())
  
  @@unique([projectId, studentId])
}

model ProjectTask {
  id          String @id @default(uuid())
  projectId   String
  project     ResearchProject @relation(fields: [projectId], references: [id])
  title       String
  description String @db.Text
  status      String // "PENDING", "IN_PROGRESS", "COMPLETED"
  createdAt   DateTime @default(now())
}

model ProjectUpdate {
  id          String @id @default(uuid())
  projectId   String
  project     ResearchProject @relation(fields: [projectId], references: [id])
  content     String @db.Text
  authorId    String
  createdAt   DateTime @default(now())
}

model OfficialDocument {
  id          String   @id @default(uuid())
  title       String
  category    String
  fileUrl     String
  uploaderId  String
  createdAt   DateTime @default(now())
}

model AcademicEvent {
  id          String   @id @default(uuid())
  title       String
  category    String
  startDate   DateTime
  endDate     DateTime?
  sourceUrl   String
  createdAt   DateTime @default(now())
}

// 8. Proyectos Matlab
model MatlabProject {
  id            String   @id @default(uuid())
  title         String
  description   String   @db.Text
  functionality String   @db.Text
  code          String   @db.Text
  fileName      String
  uploaderId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
